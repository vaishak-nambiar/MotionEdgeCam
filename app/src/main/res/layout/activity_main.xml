<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Live processed preview (SurfaceView drawn by our processor) -->
    <SurfaceView
        android:id="@+id/surfaceView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/controlPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- REC indicator -->
    <TextView
        android:id="@+id/recIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⏺ REC"
        android:textColor="#FF3333"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_margin="12dp" />

    <!-- Bottom control panel -->
    <LinearLayout
        android:id="@+id/controlPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#CC111111"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Motion Sensitivity -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Motion"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
            <SeekBar
                android:id="@+id/seekMotion"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="3"
                android:max="80"
                android:progress="20"
                android:progressTint="#FFFFFF"
                android:thumbTint="#FFFFFF" />
            <TextView
                android:id="@+id/tvMotionVal"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:text="20"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:gravity="end" />
        </LinearLayout>

        <!-- Noise Suppression -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Noise"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
            <SeekBar
                android:id="@+id/seekNoise"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="3"
                android:max="20"
                android:progress="5"
                android:progressTint="#FFFFFF"
                android:thumbTint="#FFFFFF" />
            <TextView
                android:id="@+id/tvNoiseVal"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:text="5"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:gravity="end" />
        </LinearLayout>

        <!-- Edge Strength -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Edge"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
            <SeekBar
                android:id="@+id/seekEdge"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="3"
                android:max="80"
                android:progress="20"
                android:progressTint="#FFFFFF"
                android:thumbTint="#FFFFFF" />
            <TextView
                android:id="@+id/tvEdgeVal"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:text="20"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:gravity="end" />
        </LinearLayout>

        <!-- Record button -->
        <Button
            android:id="@+id/btnRecord"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="⏺  Start Recording"
            android:textColor="#FFFFFF"
            android:backgroundTint="#222222"
            android:strokeColor="#FFFFFF"
            android:strokeWidth="1dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
